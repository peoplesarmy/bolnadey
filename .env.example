# ─────────────────────────────────────────────
#  BOLNA DEY — Environment Variables
#  Copy this file to .env.local and fill in
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: mongodb.com/atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/bolna-dey?retryWrites=true&w=majority

# Your website URL
# Local development:
NEXTAUTH_URL=http://localhost:3000
# On Vercel (change to your real URL after deploying):
# NEXTAUTH_URL=https://your-app-name.vercel.app

# Random secret key — just type any 32+ characters
NEXTAUTH_SECRET=type-any-random-characters-here-at-least-32

# Used to protect the seed endpoint in production
SEED_SECRET=any-random-word-here
